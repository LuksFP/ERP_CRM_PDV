NODE_ENV=development
PORT=3000

# PostgreSQL — copie para .env e ajuste
DATABASE_URL="postgresql://user:password@localhost:5432/erp_dev"

# mínimo 32 caracteres — gere com: openssl rand -base64 32
JWT_SECRET="TROQUE_POR_UMA_CHAVE_SECRETA_LONGA_AQUI"
JWT_EXPIRES_IN=7d

# Origins permitidos (separados por vírgula)
CORS_ORIGINS=http://localhost:3001,http://localhost:3002
